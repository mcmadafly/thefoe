---
/**
 * The FOE brand mark: a foundation of bricks (running-bond, 3 courses).
 * Colors via `currentColor`, so set `color` on the element/wrapper.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 22, class: className } = Astro.props;
const height = +(size * (18 / 26)).toFixed(2);
---

<svg
  class={className}
  width={size}
  height={height}
  viewBox="0 0 26 18"
  fill="currentColor"
  role="img"
  aria-label="The Foundations of Software Engineering"
  focusable="false"
>
  <!-- top course -->
  <rect x="0" y="0" width="7.5" height="5" rx="1" />
  <rect x="9" y="0" width="7.5" height="5" rx="1" />
  <rect x="18" y="0" width="8" height="5" rx="1" />
  <!-- middle course (offset — running bond) -->
  <rect x="0" y="6.5" width="3.5" height="5" rx="1" />
  <rect x="5" y="6.5" width="7.5" height="5" rx="1" />
  <rect x="14" y="6.5" width="7.5" height="5" rx="1" />
  <rect x="23" y="6.5" width="3" height="5" rx="1" />
  <!-- bottom course -->
  <rect x="0" y="13" width="7.5" height="5" rx="1" />
  <rect x="9" y="13" width="7.5" height="5" rx="1" />
  <rect x="18" y="13" width="8" height="5" rx="1" />
</svg>
