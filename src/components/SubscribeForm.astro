---
/**
 * Custom-styled Beehiiv signup. The form is styled to match the site; on submit
 * it hands the email to Beehiiv's hosted subscribe page (BEEHIIV.subscribeUrl)
 * via the `email` query param, which Beehiiv pre-fills / auto-subscribes.
 *
 * Swap to the official iframe embed by setting BEEHIIV.embedUrl in src/config.ts.
 */
import { BEEHIIV, NEWSLETTER } from '../config';

interface Props {
  /** Optional id so multiple forms on one page stay distinct. */
  id?: string;
  buttonLabel?: string;
  showConsent?: boolean;
}
const {
  id = 'subscribe',
  buttonLabel = NEWSLETTER.buttonLabel,
  showConsent = true,
} = Astro.props;
---

{BEEHIIV.embedUrl ? (
  <iframe
    src={BEEHIIV.embedUrl}
    title="Subscribe to the newsletter"
    class="beehiiv-embed"
    style="width:100%;height:64px;border:0;border-radius:6px;background:transparent;"
    loading="lazy"
  ></iframe>
) : (
  <form
    class="subscribe"
    method="get"
    action={BEEHIIV.subscribeUrl}
    target="_blank"
    rel="noopener"
    data-subscribe
    id={id}
  >
    <div class="subscribe-row">
      <label class="sr-only" for={`${id}-email`}>Email address</label>
      <input
        class="subscribe-input"
        id={`${id}-email`}
        type="email"
        name="email"
        placeholder={NEWSLETTER.placeholder}
        autocomplete="email"
        required
      />
      <button class="btn btn--accent" type="submit">{buttonLabel}</button>
    </div>
    {showConsent && <p class="subscribe-consent">{NEWSLETTER.consent}</p>}
  </form>
)}

<style>
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }
</style>
