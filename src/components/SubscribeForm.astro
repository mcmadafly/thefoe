---
/**
 * Custom-styled Beehiiv signup. The form matches the site design and submits
 * via fetch to /api/subscribe, a Cloudflare Worker route that forwards the
 * signup to Beehiiv's API server-side — the visitor never leaves the site.
 *
 * (Setting BEEHIIV.embedUrl swaps in Beehiiv's official iframe embed instead.)
 */
import { BEEHIIV, NEWSLETTER } from '../config';

interface Props {
  /** Optional id so multiple forms on one page stay distinct. */
  id?: string;
  buttonLabel?: string;
  showConsent?: boolean;
}
const {
  id = 'subscribe',
  buttonLabel = NEWSLETTER.buttonLabel,
  showConsent = true,
} = Astro.props;
---

{BEEHIIV.embedUrl ? (
  <iframe
    src={BEEHIIV.embedUrl}
    title="Subscribe to the newsletter"
    class="beehiiv-embed"
    scrolling="no"
    style="width:100%;height:320px;max-width:480px;margin-inline:auto;border:0;border-radius:6px;background:transparent;display:block;"
    loading="lazy"
  ></iframe>
) : (
  <form class="subscribe" method="post" action="/api/subscribe" data-subscribe id={id}>
    <div class="subscribe-row">
      <label class="sr-only" for={`${id}-email`}>Email address</label>
      <input
        class="subscribe-input"
        id={`${id}-email`}
        type="email"
        name="email"
        placeholder={NEWSLETTER.placeholder}
        autocomplete="email"
        required
      />
      <button class="btn btn--accent" type="submit" data-subscribe-btn>{buttonLabel}</button>
    </div>
    {showConsent && <p class="subscribe-consent">{NEWSLETTER.consent}</p>}
    <p class="subscribe-status" data-subscribe-status role="status" aria-live="polite" hidden></p>
  </form>
)}

<style>
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('form[data-subscribe]').forEach((form) => {
    const btn = form.querySelector<HTMLButtonElement>('[data-subscribe-btn]');
    const input = form.querySelector<HTMLInputElement>('input[type="email"]');
    const status = form.querySelector<HTMLElement>('[data-subscribe-status]');
    const defaultLabel = btn?.textContent ?? 'Subscribe';

    const setStatus = (msg: string, kind: 'ok' | 'error' | '') => {
      if (!status) return;
      status.textContent = msg;
      status.hidden = !msg;
      status.dataset.kind = kind;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = input?.value.trim() ?? '';
      if (!email) return;

      if (btn) { btn.disabled = true; btn.textContent = 'Subscribing…'; }
      setStatus('', '');

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'content-type': 'application/json', accept: 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          form.reset();
          setStatus("You're in. Check your inbox to confirm.", 'ok');
        } else {
          setStatus(data.error || 'Something went wrong. Please try again.', 'error');
        }
      } catch {
        setStatus('Network error. Please try again.', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = defaultLabel; }
      }
    });
  });
</script>
