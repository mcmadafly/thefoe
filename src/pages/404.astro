---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="That page wandered off.">
  <div class="wrap">
    <header class="post-hero" style="text-align:center;">
      <span class="kicker post-kicker" style="justify-content:center;">Error<span class="dot">·</span>404</span>
      <h1 class="post-title">This page wandered off.</h1>
      <p class="post-dek" style="margin-inline:auto; max-width:34ch;">
        No foundation here — just a missing one. Let's get you back to solid ground.
      </p>
      <p style="margin-top:8px;">
        <a class="cta-bracket" href="/">Back to the essays</a>
      </p>
    </header>
  </div>
</BaseLayout>
